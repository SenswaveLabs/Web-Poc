@using Senswave.Web.Services.Shared.Loading

@inherits LayoutComponentBase
@inject ILoadingService loadingService



<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudOverlay Visible="_isLoading" DarkBackground="true">
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
</MudOverlay>

<AuthorizeView>
    <Authorized>
        <MudLayout Elevation="2" Class="main-layout">

            <MudAppBar>
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" Edge="Edge.End" />
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
                <MudDrawerHeader>
                    <MudText Typo="Typo.h5" Class="mt-1">Application</MudText>
                </MudDrawerHeader>
            </MudDrawer>

            <MudMainContent>
                @Body
            </MudMainContent>

        </MudLayout>
    </Authorized>
    <NotAuthorized>
        <MudLayout Class="main-layout" Style="overflow:hidden; height: 100vh;">
            @Body
        </MudLayout>
    </NotAuthorized>
</AuthorizeView>

@code {
    bool _drawerOpen = true;
    private bool _isLoading;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    protected override void OnInitialized()
    {
        loadingService.OnChange += StateChanged;
        _isLoading = loadingService.Loading;
    }

    private void StateChanged()
    {
        _isLoading = loadingService.Loading;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        loadingService.OnChange -= StateChanged;
    }
}