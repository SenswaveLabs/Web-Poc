@using Senswave.Web.Shared.Services
@using Senswave.Web.Themes
@using Senswave.Web.Users.Auth.Services

@inherits LayoutComponentBase
@inject ILoadingService LoadingService
@inject IThemeService ThemeService

<MudThemeProvider IsDarkMode="false" Theme="@_currentTheme"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudOverlay Visible="LoadingService.Loading" DarkBackground="true">
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
</MudOverlay>

<AuthorizeView>
    <Authorized>
        <MudLayout Elevation="2" Class="main-layout d-flex" Style="overflow:hidden; height: 100vh;">
            <NavigationLayout />
            <MudMainContent Class="d-flex flex-column">
                @Body
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        <MudLayout Class="main-layout" Style="overflow:hidden; height: 100vh;">
            @Body
        </MudLayout>
    </NotAuthorized>
</AuthorizeView>

@code {
    private MudTheme _currentTheme = new();


    protected override async Task OnInitializedAsync()
    {
        LoadingService.OnChange += StateChanged;
        ThemeService.OnChange += ThemeChanged;

        await ThemeService.Initialize();
    }

    private void ThemeChanged()
    {
        _currentTheme = ThemeService.CurrentTheme;
        InvokeAsync(StateHasChanged);
    }

    private void StateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LoadingService.OnChange -= StateChanged;
    }
}