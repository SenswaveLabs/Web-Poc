@using Senswave.Web.Homes.Models
@using Senswave.Web.Homes.Services
@using Senswave.Web.Shared.Services
@using Senswave.Web.Users.Auth.Services

@inject ILoadingService LoadingService
@inject ISnackbar Snackbar
@inject IAuthenticationService AuthenticationService
@inject IHomeService HomeService

<MudNavMenu Rounded="true" Margin="Margin.Dense">
    <MudNavLink Match="NavLinkMatch.Prefix" Href="/home/devices" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    <MudNavLink Match="NavLinkMatch.Prefix" Href="/home/automations" Icon="@Icons.Material.Filled.Bookmark">Automations</MudNavLink>
    <MudNavLink Match="NavLinkMatch.Prefix" Href="/home/details" Icon="@Icons.Material.Filled.Info">Details</MudNavLink>

    <MudDivider Class="my-1" />

    <MudNavLink Match="NavLinkMatch.Prefix" Href="/home/select" Icon="@Icons.Material.Filled.SwapHoriz">Switch Home</MudNavLink>
    <MudNavLink Match="NavLinkMatch.Prefix" Href="/datasources" Icon="@Icons.Material.Filled.Hub">Data Sources</MudNavLink>
    <MudNavLink Match="NavLinkMatch.Prefix" Href="/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>

    <MudDivider Class="my-1" />

    <MudNavLink IconColor="Color.Error" Icon="@Icons.Material.Filled.Logout" OnClick="HandleLogout">Logout</MudNavLink>
</MudNavMenu>

<MudSpacer/>

<MudItem>
    @*Current home if available*@
</MudItem>

@code {
    string SyncKey = "Auth:Logout";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();



    }  

    public async Task HandleLogout()
    {
        try
        {
            LoadingService.Show(SyncKey);
            await AuthenticationService.Logout();
            Snackbar.Add("Logged out.", Severity.Info);
        }
        finally
        {
            LoadingService.Hide(SyncKey);
        }
    }
}
