@using Senswave.Web.Extensions
@using Senswave.Web.Homes.Models

<MudPaper Class="d-flex align-items-center p-3 gap-3 cursor-pointer"
          Style="width:100%; height:100%;"
          Elevation="1"
          @onclick="HandleClick">

    <!-- Icon -->
    <MudIcon Icon="@ResolveIcon(Home.Icon)"
             Size="Size.Large"
             Color="Color.Primary" />

    <!-- Content -->
    <div class="d-flex flex-column flex-grow-1">

        <MudText Typo="Typo.subtitle1" Class="fw-bold">@Home.Name</MudText>

        <div class="d-flex flex-wrap gap-1 mt-1">

            @if (Home.IsOwner)
            {
                <MudChip T="string"
                         Color="Color.Success"
                         Variant="Variant.Outlined"
                         Size="Size.Small">
                    Owner
                </MudChip>
            }


        </div>

    </div>

    <!-- Actions -->
    <MudMenu Icon="@Icons.Material.Filled.MoreVert"
             Dense="true"
             AnchorOrigin="Origin.TopRight"
             TransformOrigin="Origin.TopRight"
             OnClick:stopPropagation="true">

        <MudMenuItem OnClick="HandleEdit">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="me-2" />
            Edit
        </MudMenuItem>

        <MudMenuItem OnClick="HandleRemove">
            <MudIcon Icon="@Icons.Material.Filled.Delete" Class="me-2" />
            Remove
        </MudMenuItem>

    </MudMenu>

</MudPaper>

@code {

    [Parameter]
    public Home Home { get; set; } = default!;

    [Parameter]
    public EventCallback<Home> OnClick { get; set; }

    [Parameter]
    public EventCallback<Home> OnEdit { get; set; }

    [Parameter]
    public EventCallback<Home> OnRemove { get; set; }

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(Home);
    }

    private async Task HandleEdit()
    {
        if (OnEdit.HasDelegate)
            await OnEdit.InvokeAsync(Home);
    }

    private async Task HandleRemove()
    {
        if (OnRemove.HasDelegate)
            await OnRemove.InvokeAsync(Home);
    }

    private string ResolveIcon(string icon)
    {
        if (string.IsNullOrWhiteSpace(icon))
            return Icons.Material.Filled.Home;

        return icon.TranslateIcon();
    }

}