@using Microsoft.Extensions.Logging
@using MudBlazor
@using Senswave.Web.DataSources.Components
@using Senswave.Web.DataSources.Integration
@using Senswave.Web.Homes.Models
@using Senswave.Web.Homes.Services
@using Senswave.Web.Shared.Components

@inject IBrokerIntegrationService BrokerIntegrationService
@inject ILogger<SensHome> Logger
@inject IHomeService HomeService

<MudPaper Class="d-flex align-items-center p-3 gap-3 cursor-pointer"
          tabindex="0"
          Style="width:100%; height:100%;"
          Elevation="1"
          @onkeydown="(e) => OnKeyDown(e)"
          @onclick="HandleClick">

    <SensIcon Icon="@Home.Icon"
              Size="Size.Large"
              Color="Color.Primary" />

    <div class="d-flex flex-column flex-grow-1">

        <MudText Typo="Typo.subtitle1" Class="fw-bold">@Home.Name</MudText>

        <div class="d-flex flex-wrap gap-0 mt-1">

            @if (IsCurrentHome())
            {
                <MudTooltip Text="Currently you see status and devices of this home.">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Variant="Variant.Outlined"
                             Icon="@Icons.Material.Rounded.MyLocation">
                        Current
                    </MudChip>
                </MudTooltip>
            }

            @if (Home.IsOwner)
            {
                <MudTooltip Text="You have created this home so you have the biggest rights to manage it.">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Success"
                             Variant="Variant.Outlined"
                             Icon="@Icons.Material.Outlined.Star">
                        Owner
                    </MudChip>
                </MudTooltip>


                <SensDataSourcesStateChip ConnectionStatus="@ConnectionState" />
            }
            else
            {
                <MudTooltip Text="You have been invited to this home.">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Secondary"
                             Variant="Variant.Outlined"
                             Icon="@Icons.Material.Outlined.Person">
                        Member
                    </MudChip>
                </MudTooltip>
            }
        </div>
    </div>
</MudPaper>

@code {

    [Parameter]
    public Home Home { get; set; } = default!;

    [Parameter]
    public EventCallback<Home> OnClick { get; set; }

    [Parameter]
    public EventCallback<Home> OnEdit { get; set; }

    [Parameter]
    public EventCallback<Home> OnRemove { get; set; }

    private string ConnectionState { get; set; } = "Loading";

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        _ = LoadConnectionState();
    }

    private async Task LoadConnectionState()
    {
        try
        {
            if (Home.DataSourceId is null)
            {
                ConnectionState = "Unknown";
                return;
            }

            var result = await BrokerIntegrationService.GetClientStateAsync(Home.DataSourceId);

            ConnectionState = result.ConnectionStatus;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to get state for data source");
            ConnectionState = "Unknown";
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool IsCurrentHome() => HomeService.CurrentHome?.Id == Home.Id;

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(Home);
    }

    private async Task HandleEdit()
    {
        if (OnEdit.HasDelegate)
            await OnEdit.InvokeAsync(Home);
    }

    private async Task HandleRemove()
    {
        if (OnRemove.HasDelegate)
            await OnRemove.InvokeAsync(Home);
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            if (OnClick.HasDelegate)
                await OnClick.InvokeAsync(Home);
        }
    }
}