@using Senswave.Web.Extensions
@using Senswave.Web.Homes.Models
@using Senswave.Web.Homes.Services
@using Senswave.Web.Shared.Services
@using Senswave.Web.Users.Auth.Services

@implements IDisposable

@inject ILoadingService LoadingService
@inject ISnackbar Snackbar
@inject IAuthenticationService AuthenticationService
@inject IHomeService HomeService

<MudNavMenu Rounded="true" Margin="Margin.Dense">

    @if (HomeService.CurrentHome is not null)
    {
        <MudNavLink Match="NavLinkMatch.Prefix" Href="/devices/list" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
        <MudNavLink Match="NavLinkMatch.Prefix" Href="/automations/list" Icon="@Icons.Material.Filled.Bookmark">Automations</MudNavLink>
        <MudNavLink Match="NavLinkMatch.Prefix" Href="/homes/details" Icon="@Icons.Material.Filled.Info">Details</MudNavLink>

        <MudDivider Class="my-1" />
    }

    <MudNavLink Match="NavLinkMatch.Prefix" Href="/homes/list" Icon="@Icons.Material.Filled.SwapHoriz">Switch Home</MudNavLink>
    <MudNavLink Match="NavLinkMatch.Prefix" Href="/datasources/list" Icon="@Icons.Material.Filled.Hub">Data Sources</MudNavLink>
    <MudNavLink Match="NavLinkMatch.Prefix" Href="/users/details" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>

    <MudDivider Class="my-1" />

    <MudNavLink IconColor="Color.Error" Icon="@Icons.Material.Filled.Logout" OnClick="HandleLogout">Logout</MudNavLink>
</MudNavMenu>

<MudSpacer/>
@code {
    string SyncKey = "Auth:Logout";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        HomeService.OnChange += Rerender;
    }

    public async Task HandleLogout()
    {
        try
        {
            LoadingService.Show(SyncKey);
            await AuthenticationService.Logout();
            Snackbar.Add("Logged out.", Severity.Info);
        }
        finally
        {
            LoadingService.Hide(SyncKey);
        }
    }

    public void Dispose()
    {
        HomeService.OnChange -= Rerender;
    }

    void Rerender()
    {
        StateHasChanged();
    }
}
