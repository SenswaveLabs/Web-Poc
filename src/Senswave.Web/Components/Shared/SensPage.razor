@inherits MudComponentBase

<MudContainer MaxWidth="MaxWidth.False" Class="pl-0 pr-0 d-flex flex-column overflow-scroll" Style=" overflow-y: auto!important; overflow-x: hidden!important;">
    <MudContainer MaxWidth="MaxWidth.False" Class="p-1 p-md-3 p-lg-4 pt-5 d-flex flex-column">
        @if (Loading)
        {
            @LoadingContent
        }
        else if (FailedToLoad)
        {
            @FailedContent
        }
        else
        {
            @LoadedContent
        }
    </MudContainer>
</MudContainer>

@code 
{
    [Parameter]
    public RenderFragment? LoadedContent { get; set; }

    [Parameter]
    public RenderFragment? FailedContent { get; set; }

    [Parameter]
    public RenderFragment? LoadingContent { get; set; }

    [Parameter]
    public bool FailedToLoad { get; set; } = false;

    [Parameter]
    public bool Loading { get; set; } = false;
}