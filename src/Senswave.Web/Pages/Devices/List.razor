@page "/devices/list"
@attribute [Authorize]

@using Senswave.Web.Components.Shared
@using Senswave.Web.Homes.Services
@using Senswave.Web.Shared.Services
@using Senswave.Web.Users.Users.Services

@inject IUserService UserService
@inject IHomeService HomeService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ILogger<List> Logger

<PageTitle>Home Dashboard</PageTitle>

<SensPage Loading="@_loading" FailedToLoad="@_failedToLoad" RefreshContent="@RefreshPage">
    <LoadingContent>
        @foreach(var i in new int[] { 1, 2, })
        {
            <MudContainer xs="12" MaxWidth="MaxWidth.False" Gutters="false" Class="m-1">
                <MudSkeleton Width="10vh" Style="min-width:96px; max-width:256px;" />
            </MudContainer>

            <MudContainer MaxWidth="MaxWidth.False" Gutters="false" Class="d-flex flex-column">
                <MudGrid Spacing="0" Class="p-0 d-flex flex-row flex-wrap">
                    <MudItem  xs="12" sm="6" md="4" lg="3">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2" Style="min-height:96px;"  />
                    </MudItem>
                    <MudItem   xs="12" sm="6" md="4" lg="3">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2" Style="min-height:96px;" />
                    </MudItem>
                    <MudItem  xs="12" sm="6" md="4" lg="3">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2" Style="min-height:96px;" />
                    </MudItem>
                </MudGrid>
            </MudContainer>
        }
    </LoadingContent>
    <Content>

    </Content>
</SensPage>

@code {
    private bool _loading = true;
    private bool _failedToLoad = true;



    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await UserService.Initialize();
        await HomeService.Initialize();
        await HomeService.Initialize();

        if (HomeService.CurrentHome is null)
        {
            Navigation.NavigateTo("/homes/list");
            return;
        }

        await RefreshPage();
    }

    private async Task RefreshPage()
    {
        try
        {
            _loading = true;

            // TODO: Load devices for the current home here

            _failedToLoad = false;
        }
        catch (Exception ex)
        {
            _failedToLoad = true;
            Logger.LogError(ex, "Failed to load page.");
        }
        finally
        {
            _loading = false;
        }
    }
}