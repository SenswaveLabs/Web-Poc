@page "/devices/dashboard/{Id}"
@attribute [Authorize]

@using Senswave.Web.Devices.Components
@using Senswave.Web.Devices.Integration
@using Senswave.Web.Shared.Components
@using Senswave.Web.Shared.Resulting

@inject ILogger<Dashboard> Logger
@inject IDashboardIntegrationService DashboardIntegrationService
@inject ISnackbar Snackbar
@inject IErrorFactory ErrorFactory
@inject NavigationManager Navigation

<PageTitle>@(CurrentDashboard?.Name ?? "Device Dashboard")</PageTitle>

<style>
    /* MudCarousel has internal wrappers that don't always stretch. This fixes it. */
    .mud-carousel-item-container {
        height: 100%;
        display: flex;
        flex-direction: column;
    }
</style>

<SensPage Loading="@_loading" FailedToLoad="@_failedToLoad" RefreshContent="@RefreshPage">
    <LoadingContent>

        <MudContainer Class="flex-1 justify-content-center align-items-center">
            <MudContainer MaxWidth="MaxWidth.False" Gutters="false" Class="m-1">
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2" Style="min-height:64px; width:256px;" />
                </MudItem>
            </MudContainer>

            <MudContainer MaxWidth="MaxWidth.False" Gutters="false" Class="d-flex flex-column">
                <MudGrid Spacing="0" Class="p-0 d-flex flex-row flex-wrap justify-content-center align-content-center">
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2" Style="width: 256px; height: 65vh;" />
                    </MudItem>

                </MudGrid>
            </MudContainer>
        </MudContainer>

    </LoadingContent>
    <Content>

        <MudContainer MaxWidth="MaxWidth.Medium"
                      Class="d-flex flex-column p-0"
                      Style="height: calc(100vh - 80px); overflow: hidden;">
            @if (Configuration != null)
            {
                <MudCarousel ShowArrows="true"
                             ShowBullets="false"
                             EnableSwipeGesture="true"
                             AutoCycle="false"
                             TData="object"
                             Class="flex-grow-1"
                             Style="height: 100%;">
                    <MudCarouselItem Transition="Transition.Slide">
                        @* This div is the key to passing height to the child component *@
                        <div class="d-flex flex-column mud-height-full mud-width-full">
                            <SensDashboard Rows="Configuration.Rows"
                                           Name="@(CurrentDashboard?.Name ?? string.Empty)"
                                           Columns="Configuration.Columns"
                                           PositionedWidgets="@Configuration.PositionedWidgets"
                                           CalculatedWidgets="@Configuration.CalculatedWidgets" />
                        </div>
                    </MudCarouselItem>
                </MudCarousel>
                
                @* <div class="d-flex align-center justify-center gap-4 py-2">
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                   OnClick="Previous"
                                   Disabled="@(_currentIndex == 0)" />

                    @* Manual Bullets *@
                    @for (int i = 0; i < TotalDashboards; i++)
                    {
                        var index = i;
                        <MudIcon Icon="@(index == _currentIndex ? Icons.Material.Filled.Circle : Icons.Material.Filled.RadioButtonUnchecked)"
                                 Size="Size.Small"
                                 @onclick="() => _currentIndex = index"
                                 Style="cursor: pointer;"
                                 Color="@(index == _currentIndex ? Color.Primary : Color.Default)" />
                    }

                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                   OnClick="Next"
                                   Disabled="@(_currentIndex == TotalDashboards - 1)" />
                </div> *@
            }

            <MudFabMenu Class="position-absolute m-3 m-lg-4"
                        Style="right:0;bottom:0;"
                        StartIcon="@Icons.Material.Rounded.MoreVert"
                        Color="Color.Secondary"
                        @bind-Open="@_open" Fixed="@_fixed">

                <MudFabMenuItem StartIcon="@Icons.Material.Rounded.Refresh"
                                Color="Color.Secondary"
                                OnClick="RefreshPage" />

                @* <MudFabMenuItem StartIcon="@Icons.Material.Rounded.Add"
                                Color="Color.Secondary"
                                OnClick="AddDashboard" />  *@


            </MudFabMenu>
        </MudContainer>
    </Content>
</SensPage>

@code {

    private int _currentIndex = 0;
    private int TotalDashboards = 2; // Derived from your Dashboards list

    private void Next() => _currentIndex = Math.Min(TotalDashboards - 1, _currentIndex + 1);
    private void Previous() => _currentIndex = Math.Max(0, _currentIndex - 1);

    private bool _open;
    private bool _fixed;
    private bool _loading = true;
    private bool _failedToLoad = true;

    [Parameter]
    public string Id { get; set; } = string.Empty;

    private List<DashboardDto> Dashboards = [];

    private DashboardDto? CurrentDashboard { get; set; }

    private GridDashboardConfiguration? Configuration { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        await RefreshPage();
    }

    private async Task RefreshPage()
    {
        try
        {
            var dashboards = await DashboardIntegrationService.DisplayDashboardsAsync(Id);

            Dashboards = dashboards.Items;
        }
        catch (Refit.ApiException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            Snackbar.Add("Create some dashboards first!", Severity.Warning);
            Navigation.NavigateTo($"/devices/details/{Id}");
        }
        catch (Refit.ApiException ex)
        {
            var result = await ErrorFactory.FromApiExceptionAsync(ex, "FailedToLoadDashboard");
            Snackbar.Add(result.Errors.First().Description, Severity.Error);
        }

        try
        {
            if (Dashboards.Select(x => x.Id).Contains(CurrentDashboard?.Id))
            {
                Logger.LogInformation("Dashboard still exists");
            }
            else
            {
                CurrentDashboard = Dashboards.First();
            }

            var details = await DashboardIntegrationService.GetDashboardDisplayAsync(CurrentDashboard!.Id);

            Configuration = details.Configuration;

            _failedToLoad = false;
        }
        catch (Refit.ApiException ex)
        {
            var result = await ErrorFactory.FromApiExceptionAsync(ex, "FailedToLoadDashboard");
            Snackbar.Add(result.Errors.First().Description, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to load dashboard", Severity.Error);
        }
        finally
        {
            _loading = false;
        }

    }

}
