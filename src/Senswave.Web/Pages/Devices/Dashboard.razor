@page "/home/devices"
@attribute [Authorize]

@using Senswave.Web.Components.Shared
@using Senswave.Web.Homes.Services
@using Senswave.Web.Shared.Services

@inject IHomeService HomeService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Home Dashboard</PageTitle>

<SensPage Loading="@_loading">
    <LoadingContent>
        @foreach(var i in new int[] { 1, 2, 3 })
        {
            <MudSkeleton Class="pt-3" />
            <MudItem Class="d-flex flex-row">
                <MudSkeleton Class="pt-3" Style="height:200px"/>
                <MudSkeleton Class="pt-3" />
            </MudItem>
        }
    </LoadingContent>
    <LoadedContent>

    </LoadedContent>
</SensPage>

@code {
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        await HomeService.Initialize();

        if (HomeService.CurrentHome is null)
        {
            Navigation.NavigateTo("/home/list");
            return;
        }

        try
        {
            _loading = true;

        }
        finally
        {
            //isLoading = false;
        }
    }

}