@page "/home/devices"
@attribute [Authorize]

@using Senswave.Web.Components.Shared
@using Senswave.Web.Homes.Services
@using Senswave.Web.Shared.Services

@inject IHomeService HomeService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Home Dashboard</PageTitle>

<SensPage Loading="@_loading">
    <LoadingContent>
        @foreach(var i in new int[] { 1, 2, 3 })
        {
            <MudContainer MaxWidth="MaxWidth.False" Gutters="false" Class="d-flex flex-column">
                <MudContainer xs="12" MaxWidth="MaxWidth.False" Gutters="false" Class="m-1">
                    <MudSkeleton Width="256px" />
                </MudContainer>
                <MudGrid Spacing="0" Class="p-0 d-flex flex-row flex-wrap">
                    <MudItem  xs="12" sm="6" md="4" lg="3">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2" Style="min-height:96px;"  />
                    </MudItem>
                    <MudItem   xs="12" sm="6" md="4" lg="3">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2" Style="min-height:96px;" />
                    </MudItem>
                    <MudItem  xs="12" sm="6" md="4" lg="3">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2" Style="min-height:96px;" />
                    </MudItem>
                </MudGrid>
            </MudContainer>
        }
    </LoadingContent>
    <LoadedContent>

    </LoadedContent>
</SensPage>

@code {
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        await HomeService.Initialize();

        if (HomeService.CurrentHome is null)
        {
            Navigation.NavigateTo("/home/list");
            return;
        }

        try
        {
            _loading = true;

        }
        finally
        {
            //isLoading = false;
        }
    }

}