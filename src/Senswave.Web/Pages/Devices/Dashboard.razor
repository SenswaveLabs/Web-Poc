@page "/devices/dashboard/{Id}"
@attribute [Authorize]

@using Senswave.Web.Devices.Components
@using Senswave.Web.Devices.Integration
@using Senswave.Web.LiveUpdate.Models
@using Senswave.Web.LiveUpdate.Services
@using Senswave.Web.Shared.Components
@using Senswave.Web.Shared.Resulting

@inject ILogger<Dashboard> Logger
@inject IDashboardIntegrationService DashboardIntegrationService
@inject ISnackbar Snackbar
@inject IErrorFactory ErrorFactory
@inject NavigationManager Navigation
@inject ILiveUpdateService LiveUpdateService
@inject IDialogService DialogService

@implements IDisposable

<PageTitle>@PageName()</PageTitle>

<style>
    /* MudCarousel has internal wrappers that don't always stretch. This fixes it. */
    .mud-carousel-item-container {
        height: 100%;
        display: flex;
        flex-direction: column;
    }
</style>

<SensPage Loading="@_loading" FailedToLoad="@_failedToLoad" RefreshContent="@RefreshPage" Breadcrumbs="@Breadcrumbs">
    <LoadingContent>

        <MudContainer MaxWidth="MaxWidth.Small" Class="display-flex flex-1 justify-content-center align-items-center">
            <MudGrid Class="display-flex flex-1 justify-content-center align-items-center">
                <MudItem Class="display-flex flex-1 justify-content-center align-items-center" xs="12">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2 flex-grow-1 display-flex" Style="height: 65vh;" />
                </MudItem>

                <MudItem xs="12">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="m-2" Style="height: 8vh;" />
                </MudItem>
            </MudGrid>
        </MudContainer>

    </LoadingContent>
    <Content>
        <MudContainer MaxWidth="MaxWidth.Small"
                      Class="d-flex flex-column p-0"
                      Style="height: calc(100vh - 80px); overflow: hidden;">
            @if (CurrentConfiguration != null)
            {
                <MudCarousel ShowArrows="false"
                             ShowBullets="false"
                             EnableSwipeGesture="false"
                             AutoCycle="false"
                             TData="object"
                             Class="flex-grow-1"
                             Style="height: calc(100% - var(--mud-appbar-height));">
                    <MudCarouselItem Transition="Transition.Slide">
                        <div class="d-flex flex-column mud-height-full mud-width-full">
                            <SensDashboard Rows="CurrentConfiguration.Rows"
                                           Id="@CurrentDashboard!.Id"
                                           Name="@(CurrentDashboard?.Name ?? string.Empty)"
                                           @bind-EditMode="EditMode"
                                           Columns="CurrentConfiguration.Columns"
                                           PositionedWidgets="@CurrentConfiguration.PositionedWidgets"
                                           CalculatedWidgets="@CurrentConfiguration.CalculatedWidgets"
                                           OnUnlinkWidget="UnlinkWidget"
                                           OnAddWidget="CreateWidget"/>
                        </div>
                    </MudCarouselItem>
                </MudCarousel>
                
                <div class="d-flex align-center justify-center gap-3 py-2" style="min-height: 64px!important;">
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                   OnClick="Previous"
                                   Class="pr-0"
                                   Disabled="@(_currentIndex == 0)" />

                  
                    @for (int i = 0; i < Dashboards.Count; i++)
                    {
                        var index = i;
                        <MudIcon Icon="@(index == _currentIndex ? Icons.Material.Filled.Circle : Icons.Material.Filled.RadioButtonUnchecked)"
                                 Size="Size.Small"
                                 @onclick="() => OnClick(index)"
                                 Style="cursor: pointer;"
                                 Color="@(index == _currentIndex ? Color.Primary : Color.Default)" />
                    }

                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                   OnClick="Next"
                                   Class="pl-0"
                                   Disabled="@(_currentIndex == Dashboards.Count - 1)" />
                </div> 
            }


            @if(EditMode)
            {
                <MudFabMenu Class="position-absolute m-3 m-lg-4"
                            Style="right:0;bottom:0;"
                            StartIcon="@Icons.Material.Rounded.MoreVert"
                            Color="Color.Secondary"
                            Open="true" Fixed="@_fixed">

                    <MudFabMenuItem StartIcon="@Icons.Material.Rounded.Check"
                                    Color="Color.Secondary"
                                    OnClick="ToogleEditMode" />

                    <MudFabMenuItem StartIcon="@Icons.Material.Filled.EditOff"
                                    Color="Color.Secondary"
                                    OnClick="ToogleEditMode" />

                </MudFabMenu>
            }
            else
            {
                <MudFabMenu Class="position-absolute m-3 m-lg-4"
                            Style="right:0;bottom:0;"
                            StartIcon="@Icons.Material.Rounded.MoreVert"
                            Color="Color.Secondary"
                            @bind-Open="@_open" Fixed="@_fixed">

                    <MudFabMenuItem StartIcon="@Icons.Material.Rounded.Refresh"
                                    Color="Color.Secondary"
                                    OnClick="RefreshPage" />

                    <MudFabMenuItem StartIcon="@Icons.Material.Rounded.OpenInNew"
                                    Color="Color.Secondary"
                                    OnClick="DeviceDetails" />

                    <MudFabMenuItem StartIcon="@Icons.Material.Filled.Edit"
                                    Color="Color.Secondary"
                                    OnClick="ToogleEditMode" />

                </MudFabMenu>
            }

        </MudContainer>
    </Content>
</SensPage>

@code {

    private List<BreadcrumbItem> Breadcrumbs => [
        new("Home Dashboard", "/devices", false, $"{Icons.Material.Filled.Dashboard}"),
        new($"{PageName()}", null, true, $"{Icons.Material.Filled.SpaceDashboard}")
    ];

    private string PageName() => CurrentDashboard?.Name ?? "Device Dashboard";

    private int _currentIndex = 0;

    private void Next()
    {
        if (Dashboards.Count == 0) return;

        _currentIndex = Math.Min(Dashboards.Count - 1, _currentIndex + 1);
        UpdateActiveDashboard();
    }

    private void Previous()
    {
        if (Dashboards.Count == 0) return;

        _currentIndex = Math.Max(0, _currentIndex - 1);
        UpdateActiveDashboard();
    }

    private void OnClick(int index)
    {
        if (Dashboards.Count == 0) return;

        _currentIndex = index;
        UpdateActiveDashboard();
    }

    private void UpdateActiveDashboard()
    {
        CurrentDashboard = Dashboards.ElementAtOrDefault(_currentIndex);
        CurrentConfiguration = Grids.ElementAtOrDefault(_currentIndex);
        StateHasChanged();

        Logger.LogInformation("Switched to dashboard index {Index}: {Name}",
            _currentIndex, CurrentDashboard?.Name);
    }

    private bool _open;
    private bool _fixed;
    private bool _loading = true;
    private bool _failedToLoad = true;

    [Parameter]
    public string Id { get; set; } = string.Empty;

    private List<DashboardDto> Dashboards = [];

    private List<GridDashboardConfiguration> Grids = [];

    private DashboardDto? CurrentDashboard { get; set; }

    private GridDashboardConfiguration? CurrentConfiguration { get; set; }

    #region WidgetManagement

    private bool EditMode { get; set; } = false;

    private void ToogleEditMode()
    {
        EditMode = !EditMode;
        StateHasChanged();
    }

    private async Task UnlinkWidget(string dashboardId, CalculatedWidgetDto widget)
    {
        try
        {

            var result = await DialogService.ShowMessageBoxAsync(
                "Confirm Unlink", 
            $"Are you sure to unlink {widget.Name} from dashboard?", "Yes", "No", options: new DialogOptions
            {
                FullScreen = true,
                MaxWidth = MaxWidth.Medium
            });

            if (result == false)
            {
                return;
            }

            _loading = true;
            StateHasChanged();

            await DashboardIntegrationService.RemoveWidgetFromDashboardAsync(dashboardId, widget.Id);

            await LiteRefresh();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to unlink widget");
            Snackbar.Add("Failed to unlink widget. Please try again", Severity.Error);
        }
        finally
        {
            EditMode = false;
            _loading = false;
        }

        StateHasChanged();
    }

    private async Task CreateWidget(string dashboardId, string widgetId, int row, int rowSpan, int col, int colSpan)
    {
        try
        {
            _loading = true;
            StateHasChanged();

            var request = new SetWidgetOnDashboardRequest(widgetId, row, rowSpan, col, colSpan);

            await DashboardIntegrationService.SetWidgetOnDashboardAsync(dashboardId, request);

            await RefreshPage();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to place widget on dashboard");
            Snackbar.Add("Failed to place widget on dashboard. Please try again", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    #endregion

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        LiveUpdateService.OnUpdate += LiveUpdate;
        await RefreshPage();
    }

    private async Task DeviceDetails()
    {
        Navigation.NavigateTo($"/devices/details/{Id}");
    }

    private async Task RefreshPage()
    {
        try
        {
            var dashboards = await DashboardIntegrationService.DisplayDashboardsAsync(Id);

            Dashboards = dashboards.Items;
        }
        catch (Refit.ApiException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            Snackbar.Add("Create some dashboards first!", Severity.Warning);
            Navigation.NavigateTo($"/devices/details/{Id}");
            return;
        }
        catch (Refit.ApiException ex)
        {
            var result = await ErrorFactory.FromApiExceptionAsync(ex, "FailedToLoadDashboard");
            Snackbar.Add(result.Errors.First().Description, Severity.Error);
        }

        try
        {
            if (Dashboards.Select(x => x.Id).Contains(CurrentDashboard?.Id))
            {
                Logger.LogInformation("Dashboard still exists");
            }
            else
            {
                CurrentDashboard = Dashboards.First();
            }

            Grids = [];

            foreach(var dash in Dashboards)
            {
                var details = await DashboardIntegrationService.GetDashboardDisplayAsync(dash!.Id);

                Grids.Add(new GridDashboardConfiguration(
                    details.Configuration.Rows, 
                    details.Configuration.Columns, 
                    details.Configuration.PositionedWidgets, 
                    details.Configuration.CalculatedWidgets, 
                    dash.Id));
            }

            CurrentConfiguration = Grids.Where(x => x.Id == CurrentDashboard!.Id).First();
            StateHasChanged();
            _failedToLoad = false;
        }
        catch (Refit.ApiException ex)
        {
            var result = await ErrorFactory.FromApiExceptionAsync(ex, "FailedToLoadDashboard");
            Snackbar.Add(result.Errors.First().Description, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to load dashboard", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LiveUpdate(UpdateEvent updateEvent)
    {
        if (updateEvent.Type != UpdateType.WidgetsActionUpdate)
            return;

        await LiteRefresh();
    }

    private async Task LiteRefresh()
    {
        try
        {
            Grids = [];

            foreach (var dash in Dashboards)
            {
                var details = await DashboardIntegrationService.GetDashboardDisplayAsync(dash!.Id);

                Grids.Add(new GridDashboardConfiguration(
                    details.Configuration.Rows,
                    details.Configuration.Columns,
                    details.Configuration.PositionedWidgets,
                    details.Configuration.CalculatedWidgets,
                    dash.Id));
            }

            CurrentConfiguration = Grids.Where(x => x.Id == CurrentDashboard!.Id).First();
            StateHasChanged();
            _failedToLoad = false;
        }
        catch (Refit.ApiException ex)
        {
            var result = await ErrorFactory.FromApiExceptionAsync(ex, "FailedToLoadDashboard");
            Snackbar.Add(result.Errors.First().Description, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to refresh dashboard", Severity.Error);
        }
    }

    public void Dispose()
    {
        LiveUpdateService.OnUpdate -= LiveUpdate;
    }
}
