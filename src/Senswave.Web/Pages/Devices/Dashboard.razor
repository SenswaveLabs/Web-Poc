@page "/home/devices"
@attribute [Authorize]

@using Senswave.Web.Components.Shared
@using Senswave.Web.Homes.Services
@using Senswave.Web.Shared.Services

@inject IHomeService HomeService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Home Dashboard</PageTitle>

<SensPage Loading="@_loading">
    <LoadingContent>
        @foreach(var i in new int[] { 1, 2, 3 })
        {
            <MudContainer MaxWidth="MaxWidth.False" Class="d-flex flex-column" >
                <MudContainer xs="12" MaxWidth="MaxWidth.False" Class="p-0">
                    <MudSkeleton Width="50vh"/>
                </MudContainer>
                <MudContainer MaxWidth="MaxWidth.False" Class="p-0 d-flex flex-row">
                    <MudSkeleton Class="mr-1" Height="128px" Width="192px" />
                    <MudSkeleton Class="ml-1 mr-1" Width="192px" Height="128px" />
                    <MudSkeleton Class="ml-1 mr-1" Width="192px" Height="128px" />
                </MudContainer>
            </MudContainer>
        }
    </LoadingContent>
    <LoadedContent>

    </LoadedContent>
</SensPage>

@code {
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        await HomeService.Initialize();

        if (HomeService.CurrentHome is null)
        {
            Navigation.NavigateTo("/home/list");
            return;
        }

        try
        {
            _loading = true;

        }
        finally
        {
            //isLoading = false;
        }
    }

}