                             Icon="@Icons.Material.Rounded.MyLocation">
                        Current
                    </MudChip>
                </MudTooltip>
            }

            @if (Home.IsOwner)
            {
                <MudTooltip Text="You have created this home so you have the biggest rights to manage it.">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Success"
                             Variant="Variant.Outlined"
                             Icon="@Icons.Material.Outlined.Star">
                        Owner
                    </MudChip>
                </MudTooltip>
            }
            else
            {
                <MudTooltip Text="You have been invited to this home.">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Secondary"
                             Variant="Variant.Outlined"
                             Icon="@Icons.Material.Outlined.Person">
                        Member
                    </MudChip>
                </MudTooltip>
            } *@


        </div>

    </div>
</MudPaper>

@code {

    [Parameter]
    public DeviceDto Device { get; set; } = default!;

    [Parameter]
    public EventCallback<DeviceDto> OnClick { get; set; }

    protected override void OnInitialized()
    {

    }
   
    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(Device);
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            if (OnClick.HasDelegate)
                await OnClick.InvokeAsync(Device);
        }
    }
}