@using MudBlazor
@using Senswave.Web.Devices.Integration

<div style="@GetWidgetGridStyle()">
    @if (Widget.Type == "Button")
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth
                   Class="mud-height-full"
                   OnClick="OnAction"
                   OnLongPress="OnLongPress">
            @Widget.Name
        </MudButton>
    }
    else if (Widget.Type == "Switch")
    {
        <MudPaper Elevation="2"
                  Class="d-flex flex-column align-center justify-center mud-height-full"
                  Style="@($"background-color: {(IsChecked ? "var(--mud-palette-success)" : "var(--mud-palette-error)")}; color: white;")">
            <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew"
                           Color="Color.Inherit"
                           Size="Size.Large"
                           OnClick="ToggleSwitch" />
            <MudText Typo="Typo.caption" Class="px-2 text-center">@Widget.Name</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="d-flex align-center justify-center mud-height-full border-2 border-solid mud-border-error">
            <MudText Color="Color.Error" Typo="Typo.caption">Invalid</MudText>
        </MudPaper>
    }
</div>

@code {
    [Parameter] public CalculatedWidgetDto Widget { get; set; } = null!;
    [Parameter] public PositionedWidgetDto Position { get; set; } = null!;
    [Parameter] public EventCallback OnLongPress { get; set; }

    // Improved null-safe check for JsonNode
    private bool IsChecked =>
        Widget.Configuration?.Runtime?.Value?.GetValueKind() == System.Text.Json.JsonValueKind.True ||
        (Widget.Configuration?.Runtime?.Value?.ToString().ToLower() == "true");

    private string GetWidgetGridStyle()
    {
        // grid-row: start / span value
        // grid-column: start / span value
        // CSS Grid indices are 1-based
        return $@"
            grid-row: {Position.Row + 1} / span {Position.RowSpan};
            grid-column: {Position.Column + 1} / span {Position.ColumnSpan};
            height: 100%;
            width: 100%;
        ";
    }

    private async Task OnAction() => await Task.CompletedTask;
    private async Task ToggleSwitch() => await Task.CompletedTask;
}