@using MudBlazor
@using System.ComponentModel.DataAnnotations

<MudDialog>

    <DialogContent>

        <MudForm @ref="_form">

            <MudStack Spacing="3">

                <MudText Typo="Typo.body2">
                    Enter the email address and select permission level.
                </MudText>

                <!-- EMAIL -->
                <MudTextField T="string"
                              Label="Email"
                              @bind-Value="_email"
                              Required="true"
                              Immediate="true" 
                              Validation="@(new EmailAddressAttribute { ErrorMessage = @"The email address is invalid" })" />

                <!-- ROLE SELECT -->
                <MudSelect T="string"
                           Label="Permission"
                           @bind-Value="_role"
                           Required="true"
                           RequiredError="Permission is required">

                    <MudSelectItem Value="@("Display")">
                        Display and Use Home
                    </MudSelectItem>

                    <MudSelectItem Value="@("Manage")">
                        Manage, Display and Use Home
                    </MudSelectItem>

                </MudSelect>

            </MudStack>

        </MudForm>

    </DialogContent>

    <DialogActions>

        <MudButton Variant="Variant.Text"
                   OnClick="Cancel">
            Cancel
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="_loading"
                   OnClick="Submit">

            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <span>Invite</span>
            }

        </MudButton>

    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    IMudDialogInstance? MudDialog { get; set; }

    private MudForm? _form;

    private string _email = string.Empty;

    private string _role = "Display";

    private bool _loading = false;

    async Task Submit()
    {
        await _form!.Validate();

        if (!_form.IsValid)
            return;

        _loading = true;

        try
        {
            var result = new InviteUserResult(_email, _role);

            MudDialog!.Close(DialogResult.Ok(result));
        }
        finally
        {
            _loading = false;
        }
    }

    void Cancel()
    {
        MudDialog!.Cancel();
    }

    public record InviteUserResult(string Email, string Role);
}