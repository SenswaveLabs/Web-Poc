@using MudBlazor
@using System.ComponentModel.DataAnnotations
@using Senswave.Web.DataSources.Models

<MudForm @ref="_form" Model="Model">

    <MudGrid>

        <MudItem xs="12">
        <MudTextField T="string"
                      Label="Name"
                      For="@(() => Model.Name)"
                      Value="Model.Name"
                      Immediate="true"
                      ValueChanged="OnNameChanged"
                      Required="true"
                      MaxLength="32"
                      RequiredError="Name is required" />
        </MudItem>

        <MudItem xs="12" md="6">
            <MudTextField T="string"
                          Label="Url Domain"
                          For="@(() => Model.Url)"
                          @bind-value="Model.Url"
                          ReadOnly="@Edit"
                          Required="true"
                          MaxLength="1024"
                          Pattern="^([a-zA-Z0-9-]+\.)+[a-zA-Z]{2,}$"
                          RequiredError="Domain is required" />
        </MudItem>

        <MudItem xs="12" md="6">
            <MudNumericField T="int"
                             Label="Port"
                             For="@(() => Model.Port)"
                             @bind-value="Model.Port"
                             ReadOnly="@Edit"
                             Min="1"
                             Max="65535"
                             Required="true" />
        </MudItem>

        <MudItem xs="12" md="6">
            <MudTextField T="string"
                          Label="Client Name"
                          For="@(() => Model.ClientName)"
                          @bind-value="Model.ClientName"
                          MaxLength="128"
                          ReadOnly="@Edit"
                          Required="true" />
        </MudItem>

        <MudItem xs="12" md="6">
            <MudSelect T="string"
                       Label="Protocol Version"
                       For="@(() => Model.ProtocolVersion)"
                       @bind-value="Model.ProtocolVersion"
                       ReadOnly="@Edit"
                       Required="true">

                @foreach (var option in ProtocolOptions)
                {
                    <MudSelectItem Value="@option.Value">
                        @option.Name
                    </MudSelectItem>
                }

            </MudSelect>
        </MudItem>

        <MudItem xs="12">
            <MudSwitch T="bool"
                       Label="Use TLS"
                       @bind-Value="Model.UseTls"
                       ReadOnly="@Edit"
                       Color="Color.Success" />
        </MudItem>

        @if (!Edit)
        {
            <MudDivider />

            <MudItem xs="12" md="6">
                <MudTextField T="string"
                              Label="Username"
                              For="@(() => Model.Username)"
                              @bind-value="Model.Username" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField T="string"
                              Label="Password"
                              For="@(() => Model.Password)"
                              @bind-value="Model.Password"
                              InputType="InputType.Password" />
            </MudItem>
        }

    </MudGrid>

</MudForm>

@code {

    private MudForm? _form;

    [Parameter]
    public BrokerDetailedModel Model { get; set; } = default!;

    [Parameter]
    public EventCallback<string> NameChanged { get; set; }

    private async Task OnNameChanged(string value)
    {
        Model.Name = value;
        await NameChanged.InvokeAsync(value);
    }

    [Parameter]
    public bool Edit { get; set; } = false;

    public async Task<bool> Validate()
    {
        if (_form is null)
            return false;

        await _form.Validate();

        return _form.IsValid;
    }

    public record ProtocolOption(string Name, string Value);

    private readonly List<ProtocolOption> ProtocolOptions =
    [
        new("5.0.0", "MqttV5"),
        new("3.1.1", "MqttV311"),
        new("3.1.0", "MqttV310")
    ];
}